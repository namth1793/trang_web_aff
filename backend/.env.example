PORT=5001
FRONTEND_URL=http://localhost:3000
BASE_URL=http://localhost:5001

# Admin
ADMIN_PASSWORD=admin123

# ════════════════════════════════════════════════════════════
# CHỌN 1 TRONG 2 NỀN TẢNG AFFILIATE BÊN DƯỚI
# ════════════════════════════════════════════════════════════

# ── Nền tảng 1: AccessTrade Vietnam (khuyến nghị) ───────────
# 1. Đăng ký tại: https://accesstrade.vn
# 2. Vào: Tài khoản → API → Lấy API Token
# 3. Điền vào bên dưới:

AFFILIATE_PLATFORM=accesstrade
ACCESSTRADE_API_TOKEN=your_accesstrade_api_token_here

# ── Nền tảng 2: Shopee Affiliate trực tiếp ──────────────────
# 1. Đăng ký tại: https://affiliate.shopee.vn
# 2. Vào: Dashboard → Công cụ tạo link → Lấy af_id (Affiliate ID)
# 3. Điền vào bên dưới (comment nền tảng 1 lại):

# AFFILIATE_PLATFORM=shopee
# SHOPEE_AFFILIATE_ID=your_affiliate_id_here
# SHOPEE_SMTT=0.0.9
